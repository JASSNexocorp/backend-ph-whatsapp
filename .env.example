# ─── Entorno & servidor ───────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Base de datos (PostgreSQL / TypeORM) ─────────────────────────
DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_NAME=ph_whatsapp

# ─── WhatsApp / Meta Graph API ────────────────────────────────────
URL_BASE_GRAPH_API=https://graph.facebook.com
VERSION_API=v21.0
TOKEN_ENVIAR_MSG=
TOKEN_VERIFICAR_WEBHOOK=
WHATSAPP_PHONE_NUMBER_ID=

# ─── WhatsApp — bot & catálogo ────────────────────────────────────
WHATSAPP_WEBSCRAPING_URL=https://pizzahut.com.bo/pages/whatsapp
WHATSAPP_MENU_CACHE_TTL_MS=1800000
WHATSAPP_CATALOG_SYNC_ENABLED=true
WHATSAPP_CATALOG_COLLECTION_BATCH_SIZE=4
WHATSAPP_CATALOG_PRODUCTS_PAGE_SIZE=50
WHATSAPP_CATALOG_BATCH_DELAY_MS=150
WHATSAPP_CATALOG_DEFAULT_IMAGE_URL=https://cdn.shopify.com/s/files/1/0911/7781/2252/files/portada.jpg?v=1773757800
IMAGE_BANNER=https://cdn.shopify.com/s/files/1/0911/7781/2252/files/portada.jpg?v=1773757800

# ─── WhatsApp — horario de atención ──────────────────────────────
WHATSAPP_BOT_VALIDAR_HORARIO_ATENCION=true
WHATSAPP_SUCURSAL_HORARIO_NOMBRE=
WHATSAPP_ATENCION_ZONA_HORARIA=America/La_Paz

# ─── Shopify — producción ─────────────────────────────────────────
SHOPIFY_SHOP_DOMAIN=pizza-hut-bo.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-10
SHOPIFY_GRAPHQL_MAX_RETRIES=3
SHOPIFY_GRAPHQL_RETRY_DELAY_MS=400

# ─── Shopify — desarrollo ─────────────────────────────────────────
SHOPIFY_SHOP_DOMAIN_DEV=development-pizza-hut-bo.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN_DEV=

# ─── Frontend / CORS / JWT ────────────────────────────────────────
ALLOWED_ORIGINS=https://famous-melomakarona-c4e4cf.netlify.app
URL_MENU_CLIENTE=https://famous-melomakarona-c4e4cf.netlify.app/menu
JWT_MENU_CLIENTE_SECRET=
JWT_MENU_CLIENTE_EXPIRES_IN=10h
