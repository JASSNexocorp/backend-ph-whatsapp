# Configuración de WhatsApp Graph API de Meta
URL_BASE_GRAPH_API=https://graph.facebook.com
VERSION_API=v21.0

# Tokens de META WhatsApp
TOKEN_ENVIAR_MSG=
TOKEN_VERIFICAR_WEBHOOK=dinex_pizza_hut_whatsapp_2026

# SHOPIFY CONFIGURACION
SHOPIFY_SHOP_DOMAIN=pizza-hut-bo.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-10

# ID del número de teléfono de WhatsApp (Business Phone Number ID).
WHATSAPP_PHONE_NUMBER_ID=

# Configuración de la imagen de portada
IMAGE_BANNER=https://cdn.shopify.com/s/files/1/0911/7781/2252/files/portada.jpg?v=1773757800

# Configuración del menú de WhatsApp
WHATSAPP_MENU_URL=https://pizzahut.com.bo/pages/whatsapp
WHATSAPP_MENU_CACHE_TTL_MS=1800000
WHATSAPP_CATALOG_SYNC_ENABLED=true
WHATSAPP_CATALOG_COLLECTION_BATCH_SIZE=4
WHATSAPP_CATALOG_PRODUCTS_PAGE_SIZE=50
WHATSAPP_CATALOG_BATCH_DELAY_MS=150
WHATSAPP_CATALOG_DEFAULT_IMAGE_URL=https://cdn.shopify.com/s/files/1/0911/7781/2252/files/portada.jpg?v=1773757800

# Configuración de Postgres (TypeORM).
DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=

# Nombre de la base para el módulo WhatsApp
DB_NAME=ph_whatsapp

# Puerto del servidor (opcional; si no existe, el backend usa 3000)
PORT=3000

# Entorno de la aplicacion
NODE_ENV=development

# URL base del menú web (Angular); el JWT se adjunta como query en el flujo WhatsApp.
URL_MENU_CLIENTE=https://localhost:4200/menu

# Secreto HMAC para firmar/validar el JWT de sesión de menú (mínimo 32 caracteres en producción).
JWT_MENU_CLIENTE_SECRET=
# Duración del token (ej. 2h); debe coincidir con lo acordado con negocio.
JWT_MENU_CLIENTE_EXPIRES_IN=2h
