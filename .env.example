
# Token que Meta usa para validar el webhook.
# Cuando lo cargás en Meta, tenés que que coincidir con el valor acá.
WHATSAPP_VERIFY_TOKEN=pon_aqui_tu_token

# Token para enviar mensajes por WhatsApp (Meta Cloud API).
# Este valor debe tener permisos para el número de teléfono configurado.
TOKEN_ENVIAR_MSG=pon_aqui_tu_token

# ID del número de teléfono de WhatsApp (Business Phone Number ID).
WHATSAPP_PHONE_NUMBER_ID=pon_aqui_tu_phone_number_id

# Puerto del servidor (opcional; si no existe, el backend usa 3000)
PORT=3000

# Configuración de Postgres (TypeORM).
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
# Nombre de la base para el módulo WhatsApp
DB_NAME=ph_whatsapp
