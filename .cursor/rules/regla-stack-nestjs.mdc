## AUTENTICACIÓN — JWT + Passport

### Estrategia JWT

```typescript
// infraestructura/auth/estrategias/jwt.estrategia.ts

@Injectable()
export class JwtEstrategia extends PassportStrategy(Strategy) {
  constructor(private configService: ConfigService) {
    super({
      jwtFromRequest: ExtractJwt.fromAuthHeaderAsBearerToken(),
      ignoreExpiration: false,
      secretOrKey: configService.get('JWT_SECRET'),
    });
  }

  async validate(payload: any) {
    if (!payload.sub || !payload.correo) {
      throw new UnauthorizedException('Token inválido');
    }
    return { id: payload.sub, correo: payload.correo, rol: payload.rol };
  }
}
```

### Uso en controlador

```typescript
@Get('perfil')
@UseGuards(JwtAuthGuard)
async obtenerPerfil(@Request() req) {
  return req.user;
}
```

