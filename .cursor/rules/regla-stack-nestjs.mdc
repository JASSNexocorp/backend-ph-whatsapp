## MANEJO DE ERRORES

### Excepciones de dominio

```typescript
// compartido/excepciones/dominio.excepcion.ts

export class DominioExcepcion extends Error {
  constructor(message: string) {
    super(message);
    this.name = 'DominioExcepcion';
  }
}

export class RecursoNoEncontradoExcepcion extends DominioExcepcion {
  constructor(recurso: string, id: string) {
    super(`${recurso} con ID ${id} no encontrado`);
  }
}
```

### Filtro global de errores

```typescript
// infraestructura/filtros/http-exception.filtro.ts

@Catch()
export class GlobalExceptionFilter implements ExceptionFilter {
  catch(exception: unknown, host: ArgumentsHost) {
    const ctx = host.switchToHttp();
    const response = ctx.getResponse();
    const request = ctx.getRequest();

    let status = HttpStatus.INTERNAL_SERVER_ERROR;
    let message = 'Error interno del servidor';

    if (exception instanceof HttpException) {
      status = exception.getStatus();
      message = exception.message;
    } else if (exception instanceof RecursoNoEncontradoExcepcion) {
      status = HttpStatus.NOT_FOUND;
      message = exception.message;
    }

    const esProduccion = process.env.NODE_ENV === 'production';

    response.status(status).json({
      exito: false,
      mensaje: message,
      timestamp: new Date().toISOString(),
      path: request.url,
      ...(esProduccion ? {} : { stack: exception instanceof Error ? exception.stack : undefined }),
    });
  }
}
```

> Aplicar en main.ts: `app.useGlobalFilters(new GlobalExceptionFilter())`
> En producción nunca exponer el stack trace — solo internamente en logs.

