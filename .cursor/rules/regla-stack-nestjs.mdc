## PAGINACIÓN — OBLIGATORIA EN LISTADOS

Nunca retornar una lista sin paginar — puede traer millones de registros.

```typescript
// nucleo/casos-uso/usuario/listar-usuarios.caso-uso.ts

export interface ListarUsuariosEntrada {
  pagina: number;
  limite: number;
  ordenarPor?: string;
  orden?: 'ASC' | 'DESC';
}

export interface ListarUsuariosSalida {
  datos: Usuario[];
  total: number;
  pagina: number;
  totalPaginas: number;
}

async ejecutar(entrada: ListarUsuariosEntrada): Promise<ListarUsuariosSalida> {
  const limite = Math.min(entrada.limite, 100);
  const offset = (entrada.pagina - 1) * limite;

  const [datos, total] = await this.usuarioRepo.findAndCount({
    skip: offset,
    take: limite,
    order: { [entrada.ordenarPor || 'createdAt']: entrada.orden || 'DESC' },
  });

  return {
    datos,
    total,
    pagina: entrada.pagina,
    totalPaginas: Math.ceil(total / limite),
  };
}
```

